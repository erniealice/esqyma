{
  "name": "@leapfor/esqyma",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/schema/v1/index.js",
  "types": "dist/schema/v1/index.d.ts",
  "sideEffects": false,
  "private": true,
  "scripts": {
    "generate": "buf generate --template ./buf.gen.yaml ./proto/v1",
    "generate:ddl": "buf build ./proto/v1 -o ./proto/v1/descriptors.bin && go run ./cmd/generate-ddl",
    "build": "pnpm generate && tsc",
    "build:fe-manager": "pnpm build",
    "clean": "rm -rf dist pkg/schema",
    "postinstall": "pnpm build"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.61.0",
    "@bufbuild/protobuf": "^2.10.2",
    "@bufbuild/protoc-gen-es": "^2.10.2",
    "@types/node": "^25.0.2",
    "typescript": "^5.9.3"
  }
}