# Database connection string (required for migrations)
# PostgreSQL: postgres://user:password@localhost:5432/database?sslmode=disable
# MySQL:      user:password@tcp(localhost:3306)/database
# SQL Server: sqlserver://user:password@localhost:1433?database=mydb
DATABASE_URL=postgres://postgres:postgres@localhost:5432/esqyma?sslmode=disable

# Database dialect: postgres, mysql, sqlserver
MIGRATE_DIALECT=postgres

# Migrations directory (default: migrations)
MIGRATIONS_DIR=migrations
